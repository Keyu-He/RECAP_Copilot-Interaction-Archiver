{
  "name": "copilot-archiver",
  "displayName": "Copilot Interaction Archiver",
  "description": "Archives interaction data from GitHub Copilot Chat",
  "version": "0.10.5",
  "publisher": "Copilot-Archiver",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keyu-He/copilot-interaction-archiver"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Machine Learning",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotArchiver.login",
        "title": "Copilot Archiver: Login"
      },
      {
        "command": "copilotArchiver.captureNow",
        "title": "Copilot Archiver: Capture Now"
      },
      {
        "command": "copilotArchiver.logout",
        "title": "Copilot Archiver: Logout"
      },
      {
        "command": "copilotArchiver.enableWorkspace",
        "title": "Copilot Archiver: Enable for this Workspace"
      },
      {
        "command": "copilotArchiver.disableWorkspace",
        "title": "Copilot Archiver: Disable for this Workspace"
      },
      {
        "command": "copilotArchiver.showMenu",
        "title": "Copilot Archiver: Show Menu"
      },
      {
        "command": "copilotArchiver.enableCopilotDebug",
        "title": "Copilot Archiver: Enable Copilot Debug Logging"
      }
    ],
    "configuration": {
      "title": "Copilot Interaction Archiver",
      "properties": {
        "copilotArchiver.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic snapshot capture"
        },
        "copilotArchiver.outputPath": {
          "type": "string",
          "default": ".snapshots",
          "description": "Relative path where snapshots will be stored"
        },
        "copilotArchiver.excludePatterns": {
          "type": "array",
          "default": [
            ".git",
            "node_modules",
            "__pycache__",
            ".DS_Store",
            "*.pyc",
            "GitHub Copilot Chat.log",
            ".snapshots",
            "copilot_debug_messages"
          ],
          "description": "Patterns to exclude from snapshots"
        },
        "copilotArchiver.jsonOutputEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Write Copilot debug JSON files alongside snapshots"
        },
        "copilotArchiver.jsonOutputDir": {
          "type": "string",
          "default": ".snapshots/copilot_debug_messages",
          "description": "Relative directory under workspace to write Copilot JSON outputs"
        },
        "copilotArchiver.s3.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable uploading snapshots to S3"
        },
        "copilotArchiver.backendUrl": {
          "type": "string",
          "default": "http://98.80.150.124:3000",
          "description": "URL of the Copilot Archiver Backend Server (e.g., http://98.80.150.124:3000)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3"
  }
}